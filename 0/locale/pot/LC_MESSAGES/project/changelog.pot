msgid ""
"{{ Fix }} Fixed a bug that caused `Console`'s `formatted_traceback` being "
"truncated unexpectedly when `filename` is specified. {pr}`4905`"
msgstr ""

#: ../../../project/changelog.md:669
msgid ""
"{{ Fix }} Locked `PyodideConsole.runcode` to block "
"`loadPackagesFromImports`. {pr}`4905`"
msgstr ""

#: ../../../project/changelog.md:672
msgid ""
"{{ Enhancement }} Added `checkAPIVersion` option to `loadPyodide` to allow "
"bootstrapping pyodide with a different version. {pr}`4907`"
msgstr ""

#: ../../../project/changelog.md:676
msgid ""
"{{ Enhancement }} Added `can_run_sync` to test whether or not `run_sync` "
"should work. {pr}`4913`"
msgstr ""

#: ../../../project/changelog.md:680
msgid ""
"{{ Fix }} Fixed a bug with the JSPI that made it interact incorrectly with "
"JavaScript code that iterates a `PyProxy`. {pr}`4919`"
msgstr ""

#: ../../../project/changelog.md:684
msgid ""
"{{ Fix }} Pyodide now loads correctly when `define` and `define.amd` are "
"defined in the global scope. {pr}`4866`"
msgstr ""

#: ../../../project/changelog.md:688
msgid ""
"{{ Fix }} Fixed keyboard input handling in SDL-based packages. {pr}`4865`"
