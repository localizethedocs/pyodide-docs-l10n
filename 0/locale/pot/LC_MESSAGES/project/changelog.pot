msgid ""
"{{ Fix }} Don't leak the values in a dictionary when applying `to_js` to it. "
"{pr}`4853`"
msgstr ""

#: ../../../project/changelog.md:645
msgid ""
"{{ Fix }} Loading of dynamic libraries now works slightly better in the cli "
"runner. Resolved {issue}`3865`. {pr}`4871`"
msgstr ""

#: ../../../project/changelog.md:649
msgid ""
"{{ Fix }} Restored the pre-0.26.0 behavior of calling `exit()` or raising "
"`SystemExit`. In 0.26.0 and 0.26.1, `exit()` shuts down the Python "
"interpreter. In all other versions of Pyodide it does not. {pr}`4867`"
msgstr ""

#: ../../../project/changelog.md:654
msgid ""
"{{ Fix }} Fixed a weird regression occurring in difficult to describe "
"circumstances introduced by {pr}`4837`. See {issue}`4861`. {pr}`4861`"
msgstr ""

#: ../../../project/changelog.md:658
msgid ""
"{{ Fix }} Recursive fortran functions now work correctly in scipy {issue}"
"`4818`. {pr}`4822`"
msgstr ""

#: ../../../project/changelog.md:661
msgid ""
"{{ Enhancement }} Allow setting `dont_inherit` and `optimize` for `compile` "
"in `CodeRunner` and `Console`. {pr}`4897`"
