msgid ""
"{{ Enhancement }} Added a new API `pyodide.mountNodeFS` which mounts a host "
"directory into the Pyodide file system when running in node. {pr}`4561`"
msgstr ""

#: ../../../project/changelog.md:786
msgid ""
"{{ Enhancement }} Updated `pyimport` to support `pyimport(\"module."
"attribute\")`. {pr}`4395`"
msgstr ""

#: ../../../project/changelog.md:789
msgid "FFI"
msgstr ""

#: ../../../project/changelog.md:791
msgid ""
"{{ Enhancement }} `str(jsproxy)` has been adjusted to not raise an error if "
"`jsproxy.toString` is undefined. Instead, it will use `Object.prototype."
"toString` in this case. If `jsproxy.toString` is defined and throws or is "
"not defined but `jsproxy[Symbol.toStringTag]` is defined and throws, then "
"`str` will still raise. {pr}`4574`"
msgstr ""

#: ../../../project/changelog.md:798
msgid ""
"{{ Enhancement }} Fixed a memory leak when iterating over a PyProxy. {pr}"
"`4546`"
msgstr ""

#: ../../../project/changelog.md:801
msgid ""
"{{ Enhancement }} When a dictionary is converted to JavaScript with `toJs` "
"the result is now a `LiteralMap`. String keys are accessible via direct "
"property access unless they match a function on the `Map` prototype. {pr}"
"`4576`"
msgstr ""

#: ../../../project/changelog.md:806
msgid ""
"{{ Fix }} `toJs` now works as expected on subclasses of `dict`. {pr}`4637`"
msgstr ""

#: ../../../project/changelog.md:809
msgid ""
"{{ Enhancement }} Added `PyProxy.asJsJson` method to adapt between Python "
"JSON (lists and dicts) and JavaScript JSON (Arrays and Objects). {pr}`4666`"
msgstr ""

#: ../../../project/changelog.md:813
msgid ""
"{{ Enhancement }} Added a new `callRelaxed` to PyProxies of callables that "
"discards extra arguments rather than raising a `TypeError``. {pr}`4392`"
msgstr ""

#: ../../../project/changelog.md:817
msgid ""
"{{ Enhancement }} A new `callWithOptions` method was added to PyProxies of "
"callables. {pr}`4608`"
msgstr ""

