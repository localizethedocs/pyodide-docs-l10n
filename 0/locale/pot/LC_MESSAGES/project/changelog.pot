#: ../../../project/changelog.md:619 ../../../project/changelog.md:622
#: ../../../project/changelog.md:969 ../../../project/changelog.md:1028
#: ../../../project/changelog.md:1040 ../../../project/changelog.md:1070
msgid "<span class='badge badge-info'>"
msgstr ""

#: ../../../project/changelog.md:621
msgid ""
"{{ Performance }} Method calls on a `JsProxy` are now much faster. If the "
"method has no arguments and no return value, it is about 80% faster. The "
"speedup for methods with arguments is less drastic but still quite a lot. "
"{pr}`4963`"
msgstr ""

#: ../../../project/changelog.md:626
msgid ""
"{{ Enhancement }} Updated stack switching support to handle new JSPI. {pr}"
"`4982`"
msgstr ""

#: ../../../project/changelog.md:629
msgid ""
"{{ Fix }} `pyimport(\"a.b\")` won't fail when `a` is removed by `del sys."
"modules[\"a\"]` {pr}`4993`"
msgstr ""

#: ../../../project/changelog.md:632
msgid ""
"{{ Fix }} It now works to convert a 0d Python buffer to JavaScript. {pr}"
"`5092`"
msgstr ""

#: ../../../project/changelog.md:635
msgid ""
"{{ Fix }} It now works to convert buffers of 64 bit signed or unsigned "
"integers to JavaScript. {pr}`5092`"
msgstr ""

