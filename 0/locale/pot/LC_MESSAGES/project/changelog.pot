msgstr ""

#: ../../../project/changelog.md:1483
msgid "_January 25, 2023_"
msgstr ""

#: ../../../project/changelog.md:1485
msgid ""
"{{ Breaking }} `setStdin` now accepts an extra `autoEOF` parameter. If "
"`true`, it will insert an EOF automatically after each string or buffer. "
"Defaults to `true`. This also affects the behavior of the `stdin` argument "
"to `loadPyodide`. {pr}`3488`"
msgstr ""

#: ../../../project/changelog.md:1491
msgid ""
"{{ Fix }} `from pyodide.ffi import *` doesn't raise an `ImportError` "
"anymore. {pr}`3484`"
msgstr ""

#: ../../../project/changelog.md:1494
msgid ""
"{{ Enhancement }} Pyodide displays a better message when someone calls posix "
"`exit` or `os._exit`. {pr}`3496`"
msgstr ""

#: ../../../project/changelog.md:1498 ../../../project/changelog.md:1694
msgid "Package Loading"
msgstr ""

#: ../../../project/changelog.md:1500
msgid ""
"{{ Fix }} Fix incorrect error message when loading a package include in "
"Pyodide fails. {pr}`3435`"
msgstr ""

#: ../../../project/changelog.md:1506
msgid ""
"{{ Fix }} Emscripten is no longer required to create a Pyodide virtual "
"environment. {pr}`3485`"
msgstr ""

#: ../../../project/changelog.md:1510
msgid ""
"{{ Fix }} Fixed a bug where `pyodide build` would fail on package that use "
"CMake, when run multiple times. {pr}`3445`"
msgstr ""

#: ../../../project/changelog.md:1514
msgid ""
"{{ Fix }} pyodide build: Don't pass the directory to the build backend args, "
"only pass the arguments. {pr}`3490`"
msgstr ""

#: ../../../project/changelog.md:1518
msgid ""
"{{ Fix }} `pyodide config` won't print extra messages anymore. {pr}`3483`"
msgstr ""

#: ../../../project/changelog.md:1521
msgid ""
"{{ Fix }} Pass the same environment variables for out of tree builds as for "
"in tree builds. {pr}`3495`"
msgstr ""

#: ../../../project/changelog.md:1525
msgid "Version 0.22.0"
msgstr ""

#: ../../../project/changelog.md:1527
msgid "_January 3, 2023_"
msgstr ""

#: ../../../project/changelog.md:1529
msgid ""
"[See the release notes for a summary.](https://blog.pyodide.org/posts/0.22-"
"release/)"
msgstr ""

#: ../../../project/changelog.md:1531
msgid "Deployment and testing"
msgstr ""

#: ../../../project/changelog.md:1533
msgid ""
"{{ Breaking }} `pyodide-cdn2.iodide.io` is not available anymore. Please use "
"`https://cdn.jsdelivr.net/pyodide` instead. {pr}`3150`."
msgstr ""

#: ../../../project/changelog.md:1537
msgid ""
"{{ Breaking }} We don't publish pre-built Pyodide docker images anymore. "
"Note that `./run_docker --pre-built` was not working for a while and it was "
"actually equivalent to `./run_docker`. If you need to build a single Python "
"wheel out of tree, you can use the `pyodide build` command instead. See [our "
"blog post](https://blog.pyodide.org/posts/0.21-release/#building-binary-"
"wheels-for-pyodide) for more information. {pr}`3342`."
msgstr ""

#: ../../../project/changelog.md:1545
msgid ""
"{{ Enhancement }} The releases are now called `pyodide-{version}.tar.gz` "
"rather than `pyodide-build-{version}.tar.gz` {pr}`2996`"
msgstr ""

#: ../../../project/changelog.md:1549
msgid ""
"{{ Enhancement }} Added a new release file called `pyodide-core-{version}."
"tar.gz` intended for use in Node. It contains the files needed to start "
"Pyodide and no additional packages. {pr}`2999`"
msgstr ""

#: ../../../project/changelog.md:1554
msgid ""
"{{ Enhancement }} The full test suite is now run in Safari {pr}`2578`, {pr}"
"`3095`."
msgstr ""

#: ../../../project/changelog.md:1557
msgid ""
"{{ Enhancement }} Added Gitpod configuration to the repository. {pr}`3201`"
msgstr ""

#: ../../../project/changelog.md:1560
msgid "Foreign function interface"
msgstr ""

#: ../../../project/changelog.md:1562
msgid "JsProxy / JavaScript from Python"
msgstr ""

#: ../../../project/changelog.md:1564
msgid ""
"{{ Enhancement }} Implemented `reverse`, `__reversed__`, `count`, `index`, "
"`append`, and `pop` for `JsProxy` of Javascript arrays so that they "
"implement the `collections.abc.MutableSequence` API. {pr}`2970`"
msgstr ""

#: ../../../project/changelog.md:1569
msgid ""
"{{ Enhancement }} Implemented methods `keys`, `items`, `values`, `get`, "
"`pop`, `setdefault`, `popitem`, `update`, and `clear` for `JsProxy` of map-"
"like objects so that they implement the `collections.abc.MutableMapping` "
"API. {pr}`3275`"
msgstr ""

#: ../../../project/changelog.md:1574
msgid ""
"{{ Enhancement }} It's now possible to destructure a JavaScript array, map, "
"or object returned by `as_object_map` with a `match` statement. {pr}`2906`"
msgstr ""

#: ../../../project/changelog.md:1578
msgid ""
"{{ Enhancement }} Added `then`, `catch`, and `finally_` methods to the "
"`Future`s used by Pyodide's event loop so they can be used like `Promise`s. "
"{pr}`2997`"
msgstr ""

#: ../../../project/changelog.md:1582
msgid ""
"{{ Enhancement }} `create_proxy` now takes an optional `roundtrip` "
"parameter. If this is set to `True`, then when the proxy is converted back "
"to Python, it is converted back to the same double proxy. This allows the "
"proxy to be destroyed from Python even if no reference is retained. {pr}"
"`3163`, {pr}`3369`"
msgstr ""

#: ../../../project/changelog.md:1588
msgid ""
"{{ Enhancement }} A `JsProxy` of a function now has a `__get__` descriptor "
"method, so it's possible to use a JavaScript function as a Python method. "
"When the method is called, `this` will be a `PyProxy` pointing to the Python "
"object the method is called on. {pr}`3130`"
msgstr ""

#: ../../../project/changelog.md:1594
msgid ""
"{{ Enhancement }} A `JsProxy` now has an `as_object_map` method. This will "
"treat the object as a mapping over its `ownKeys` so for instance: "
"`run_js(\"({a:2, b:3})\").as_object_map()[\"a\"]` will return 2. These "
"implement `collections.abc.MutableMapping`. {pr}`3273`, {pr}`3295`, {pr}"
"`3297`"
msgstr ""

#: ../../../project/changelog.md:1600
msgid ""
"{{ Enhancement }} Split up the `JsProxy` documentation class into several "
"classes, e.g., `JsBuffer`, `JsPromise`, etc. Implemented `issubclass` and "
"`isinstance` on the various synthetic and real `JsProxy` classes so that "
"they behave the way one might naively expect them to (or at least closer to "
"that than it was before). {pr}`3277`"
msgstr ""

#: ../../../project/changelog.md:1607
msgid ""
"{{ Enhancement }} Added type parameters to many of the `JsProxy` subtypes. "
"{pr}`3387`"
msgstr ""

#: ../../../project/changelog.md:1610
msgid ""
"{{ Enhancement }} Added `JsGenerator` and `JsIterator` types to `pyodide."
"ffi`. Added `send` method to `JsIterator`s and `throw`, and `close` methods "
"to `JsGenerator`s. {pr}`3294`"
msgstr ""

#: ../../../project/changelog.md:1615
msgid ""
"{{ Enhancement }} It is now possible to use asynchronous JavaScript "
"iterables, iterators and generators from Python. This includes support for "
"`aiter` for async interables, `anext` and `asend` for async iterators, and "
"`athrow` and `aclose` for async generators. {pr}`3285`, {pr}`3299`, {pr}"
"`3339`"
msgstr ""

#: ../../../project/changelog.md:1621
msgid ""
"{{ Enhancement }} JavaScript generators and async generators that are "
"created from Python now are wrapped so that Python objects sent to them as "
"arguments or from `.send` / `.asend` are kept alive until the generator is "
"exhausted or `.close`d. This makes generators significantly more ergonomic "
"to use, at the cost of making memory leaks more likely if the generator is "
"never finalized. {pr}`3317`"
msgstr ""

#: ../../../project/changelog.md:1628
msgid ""
"{{ Enhancement }} Added a mypy typeshed for some common functionality for "
"the `js` module. {pr}`3298`"
msgstr ""

#: ../../../project/changelog.md:1632
msgid ""
"{{ Enhancement }} mypy understands the types of more things now. {pr}`3385`"
msgstr ""

#: ../../../project/changelog.md:1635
msgid ""
"{{ Fix }} Fixed bug in `split` argument of `pyodide.console.repr_shorten`. "
"Added `shorten` function. {pr}`3178`"
msgstr ""

#: ../../../project/changelog.md:1639
msgid "PyProxy / Using Python from JavaScript"
msgstr ""

#: ../../../project/changelog.md:1641
msgid ""
"{{ Enhancement }} Added a type field to `PythonError` (e.g., a StopIteration "
"error would have `e.type === \"StopIteration\"`) {pr}`3289`"
msgstr ""

#: ../../../project/changelog.md:1645
msgid ""
"{{ Enhancement }} It is now possible to use asynchronous Python generators "
"from JavaScript. {pr}`3290`"
msgstr ""

#: ../../../project/changelog.md:1649
msgid ""
"{{ Enhancement }} PyProxies of synchronous and asynchronous Python "
"generators now support `return` and `throw` APIs that behave like the ones "
"on JavaScript generators. {pr}`3346`"
msgstr ""

#: ../../../project/changelog.md:1654
msgid ""
"{{ Enhancement }} It is possible to make a `PyProxy` that takes `this` as "
"the first argument using the `PyProxy.captureThis` method. The "
"`create_proxy` method also has a `capture_this` argument which causes the "
"`PyProxy` to receive `this` as the first argument if set to `True` {pr}"
"`3103`, {pr}`3145`"
msgstr ""

#: ../../../project/changelog.md:1662
msgid ""
"{{ Enhancement }} Users can do a static import of `pyodide/pyodide.asm.js` "
"to avoid issues with dynamic imports. This allows the use of Pyodide with "
"module-type service workers. {pr}`3070`"
msgstr ""

#: ../../../project/changelog.md:1667
msgid ""
"{{ Enhancement }} Added a new API `pyodide.mountNativeFS` which mounts a {js:"
"class}`FileSystemDirectoryHandle` into the Pyodide file system. {pr}`2987`"
msgstr ""

#: ../../../project/changelog.md:1671
msgid ""
"{{ Enhancement }} `loadPyodide` has a new option called `args`. This list "
"will be passed as command line arguments to the Python interpreter at start "
"up. {pr}`3021`, {pr}`3282`"
msgstr ""

#: ../../../project/changelog.md:1675
msgid ""
"Removed \"Python initialization complete\" message printed when loading is "
"finished. {pr}`3247"
msgstr ""

#: ../../../project/changelog.md:1679
msgid ""
"{{ Breaking }} The messageCallback and errorCallback argument to "
"`loadPackage` and `loadPackagesFromImports` is now passed as named "
"arguments. The old usage still works with a deprecation warning. {pr}`3149`"
msgstr ""

#: ../../../project/changelog.md:1684
msgid ""
"{{ Enhancement }} `loadPackage` and `loadPackagesFromImports` now accepts a "
"new option `checkIntegrity`. If set to False, integrity check for Python "
"Packages will be disabled."
msgstr ""

#: ../../../project/changelog.md:1688
msgid ""
"{{ Enhancement }} Added APIs `pyodide.setStdin`, `pyodide.setStdout`, "
"`pyodide.setStderr` for changing the stream handlers after loading Pyodide. "
"Also added more careful control over whether `isatty` returns true or false "
"on stdin, stdout, and stderr. {pr}`3268`"
msgstr ""

#: ../../../project/changelog.md:1696
msgid ""
"{{ Enhancement }} Pyodide now shows more helpful error messages when "
"importing packages that are included in Pyodide fails. {pr}`3137`, {pr}`3263`"
msgstr ""

#: ../../../project/changelog.md:1700
msgid ""
"{{ Fix }} Shared libraries with version suffixes are now handled correctly. "
"{pr}`3154`"
msgstr ""

#: ../../../project/changelog.md:1703
msgid ""
"{{ Breaking }} Unvendored the sqlite3 module from the standard library. "
"Before `sqlite3` was included by default. Now it needs to be loaded with "
"`pyodide.loadPackage` or `micropip.install`. {pr}`2946`"
msgstr ""

#: ../../../project/changelog.md:1708
msgid ""
"{{ Breaking }} The Pyodide Python package is installed into `/lib/"
"python3.10` rather than `/lib/python3.10/site-packages`. {pr}`3022`"
msgstr ""

#: ../../../project/changelog.md:1712
msgid ""
"{{ Breaking }} The matplotlib HTML5 backends are now available as part of "
"the [`matplotlib-pyodide`](https://github.com/pyodide/matplotlib-pyodide) "
"package. If you use the default backend from Pyodide, no changes are "
"necessary. However, if you previously specified the backend with `matplotlib."
"use`, the URL is now different. See [package readme](https://github.com/"
"pyodide/matplotlib-pyodide) for more details. {pr}`3061`"
msgstr ""

#: ../../../project/changelog.md:1720
msgid ""
"{{ Breaking }} The micropip package was moved to a separate repository "
"[pyodide/micropip](https://github.com/pyodide/micropip). In addion to "
"installing the version shipped with a given Pyodide release, you can also "
"install a different micropip version from [PyPi](https://pypi.org/project/"
"micropip/) with,"
msgstr ""

#: ../../../project/changelog.md:1726
msgid ""
"await pyodide.loadPackage('packaging')\n"
"await pyodide.loadPackage('<URL of the micropip wheel on PyPI>')\n"
msgstr ""

#: ../../../project/changelog.md:1731
msgid ""
"from Javascript. From Python you can import the Javascript Pyodide package,"
msgstr ""

#: ../../../project/changelog.md:1733
msgid "import pyodide_js\n"
msgstr ""

