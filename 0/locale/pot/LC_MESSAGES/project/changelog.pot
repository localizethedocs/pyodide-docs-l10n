#: ../../../project/changelog.md:1847
msgid "Version 0.21.3"
msgstr ""

#: ../../../project/changelog.md:1849
msgid "_September 15, 2022_"
msgstr ""

#: ../../../project/changelog.md:1851
msgid ""
"{{ Fix }} When loading `sqlite3`, `loadPackage` no longer also loads `nltk` "
"and `regex`. {issue}`3001`"
msgstr ""

#: ../../../project/changelog.md:1855
msgid ""
"{{ Fix }} Packages are now loaded in a topologically sorted order regarding "
"their dependencies. {pr}`3020`"
msgstr ""

#: ../../../project/changelog.md:1859
msgid ""
"{{ Breaking }} Loading the `soupsieve` package will not automatically load "
"`beautifulsoup4` together. {pr}`3020`"
msgstr ""

#: ../../../project/changelog.md:1863
msgid ""
"{{ Fix }} Fix the incorrect package name `ruamel` to `ruamel.yaml`. {pr}"
"`3036`"
msgstr ""

#: ../../../project/changelog.md:1866
msgid ""
"{{ Fix }} `loadPyodide` will now raise error when the version of JavaScript "
"and Python Pyodide package does not match. {pr}`3074`"
msgstr ""

#: ../../../project/changelog.md:1870
msgid ""
"{{ Enhancement }} Pyodide now works with a content security policy that "
"doesn't include `unsafe-eval`. It is still necessary to include `wasm-unsafe-"
"eval` (and probably always will be). Since current Safari versions have no "
"support for `wasm-unsafe-eval`, it is necessary to include `unsafe-eval` in "
"order to work in Safari. This will likely be fixed in the next Safari "
"release: https://bugs.webkit.org/show_bug.cgi?id=235408 {pr}`3075`"
msgstr ""

#: ../../../project/changelog.md:1878
msgid ""
"{{ Fix }} It works again to use `loadPyodide` with a relative URL as "
"`indexURL` (this was a regression in v0.21.2). {pr}`3077`"
msgstr ""

#: ../../../project/changelog.md:1882
msgid ""
"{{ Fix }} Add `url` to list of pollyfilled packages for webpack "
"compatibility. {pr}`3080`"
msgstr ""

#: ../../../project/changelog.md:1885
msgid ""
"{{ Fix }} Fixed warnings like `Critical dependency: the request of a "
"dependency is an expression.` when using Pyodide with webpack. {pr}`3080`"
msgstr ""

#: ../../../project/changelog.md:1890
msgid ""
"{{ Enhancement }} Add binary files to exports in JavaScript package {pr}"
"`3085`."
msgstr ""

#: ../../../project/changelog.md:1893
msgid ""
"{{ Fix }} Source maps are included in the distribution again (reverting {pr}"
"`3015` included in 0.21.2) and if there is a variable in top level scope "
"called `__dirname` we use that for the `indexURL`. {pr}`3088`"
msgstr ""

#: ../../../project/changelog.md:1898
msgid ""
"{{ Fix }} `PyProxy.apply` now correctly handles the case when something "
"unexpected is passed as the second argument. {pr}`3101`"
msgstr ""

#: ../../../project/changelog.md:1902
msgid "Version 0.21.2"
msgstr ""

#: ../../../project/changelog.md:1904
msgid "_August 29, 2022_"
msgstr ""

#: ../../../project/changelog.md:1906
msgid ""
"{{ Fix }} The standard library packages `ssl` and `lzma` can now be "
"installed with `pyodide.loadPackage(\"ssl\")` or `micropip.install(\"ssl\")` "
"(previously they had a leading underscore and it was only possible to load "
"them with `pyodide.loadPackage`). {issue}`3003`"
msgstr ""

#: ../../../project/changelog.md:1912
msgid ""
"{{ Fix }} If a wheel path is passed to `pyodide.loadPackage`, it will now be "
"resolved relative to `document.location` (in browser) or relative to the "
"current working directory (in Node) rather than relative to `indexURL`. {pr}"
"`3013`, {issue}`3011`"
msgstr ""

#: ../../../project/changelog.md:1917
msgid ""
"{{ Fix }} Fixed a bug in Emscripten that caused Pyodide to fail in Jest. {pr}"
"`3014`"
msgstr ""

#: ../../../project/changelog.md:1920
msgid ""
"{{ Fix }} It now works to pass a relative url to `indexURL`. Also, the "
"calculated index URL now works even if `node` is run with `--enable-source-"
"maps`. {pr}`3015`"
msgstr ""

#: ../../../project/changelog.md:1925
msgid "Version 0.21.1"
msgstr ""

#: ../../../project/changelog.md:1927
msgid "_August 22, 2022_"
msgstr ""

#: ../../../project/changelog.md:1929
msgid "New packages: the standard library lzma module {pr}`2939`"
msgstr ""

#: ../../../project/changelog.md:1931
msgid ""
"{{ Enhancement }} Pyodide now shows more helpful error messages when "
"importing unvendored or removed stdlib modules fails. {pr}`2973`"
msgstr ""

#: ../../../project/changelog.md:1935
msgid ""
"{{ Breaking }} The default value of `fullStdLib` in `loadPyodide` has been "
"changed to `false`. This means Pyodide now will not load some stdlib modules "
"like distutils, ssl, and sqlite3 by default. See [Pyodide Python "
"compatibility](https://pyodide.org/en/stable/usage/wasm-constraints.html) "
"for detail. If `fullStdLib` is set to `true`, it will load all unvendored "
"stdlib modules. However, setting `fullStdLib` to true will increase the "
"initial Pyodide load time. So it is preferable to explicitly load the "
"required module. {pr}`2998`"
msgstr ""

#: ../../../project/changelog.md:1944
msgid ""
"{{ Enhancement }} `pyodide build` now checks that the correct version of the "
"Emscripten compiler is used. {pr}`2975`, {pr}`2990`"
msgstr ""

#: ../../../project/changelog.md:1948
msgid ""
"{{ Fix }} Pyodide works in Safari v14 again. It was broken in v0.21.0 {pr}"
"`2994`"
msgstr ""

#: ../../../project/changelog.md:1951
msgid "Version 0.21.0"
msgstr ""

#: ../../../project/changelog.md:1953
msgid "_August 9, 2022_"
msgstr ""

#: ../../../project/changelog.md:1955
msgid ""
"[See the release notes for a summary.](https://blog.pyodide.org/posts/0.21-"
"release/)"
msgstr ""

#: ../../../project/changelog.md:1959
msgid ""
"{{ Enhancement }} Emscripten was updated to Version 3.1.14 {pr}`2775`, {pr}"
"`2679`, {pr}`2672`"
msgstr ""

#: ../../../project/changelog.md:1962
msgid "{{ Fix }} Fix building on macOS {issue}`2360` {pr}`2554`"
msgstr ""

#: ../../../project/changelog.md:1964
msgid ""
"{{ Enhancement }} Update Typescript target to ES2017 to generate more modern "
"Javascript code. {pr}`2471`"
msgstr ""

#: ../../../project/changelog.md:1968
msgid ""
"{{ Enhancement }} We now put our built files into the `dist` directory "
"rather than the `build` directory. {pr}`2387`"
msgstr ""

#: ../../../project/changelog.md:1971
msgid ""
"{{ Fix }} The build will error out earlier if `cmake` or `libtool` are not "
"installed. {pr}`2423`"
msgstr ""

#: ../../../project/changelog.md:1975
msgid ""
"{{ Enhancement }} The platform tags of wheels now include the Emscripten "
"version in them. This should help ensure ABI compatibility if Emscripten "
"wheels are distributed outside of the main Pyodide distribution. {pr}`2610`"
msgstr ""

#: ../../../project/changelog.md:1980
msgid ""
"{{ Enhancement }} The build system now uses the sysconfigdata from the "
"target Python rather than the host Python. {pr}`2516`"
msgstr ""

#: ../../../project/changelog.md:1984
msgid "{{ Enhancement }} Pyodide now builds with `-sWASM_BIGINT`. {pr}`2643`"
msgstr ""

#: ../../../project/changelog.md:1987
msgid ""
"{{ Enhancement }} Added `cross-script` key to the `meta.yaml` spec to allow "
"executing custom logic in the cross build environment. {pr}`2734`"
msgstr ""

#: ../../../project/changelog.md:1991
msgid "Pyodide Module and type conversions"
msgstr ""

#: ../../../project/changelog.md:1993
msgid ""
"{{ API }} All functions were moved out of the root `pyodide` package into "
"various submodules. For backwards compatibility, they will be available from "
"the root package (raising a `FutureWarning`) until v0.23.0. {pr}`2787`, {pr}"
"`2790`"
msgstr ""

#: ../../../project/changelog.md:1998
msgid ""
"{{ Enhancement }} `loadPyodide` no longer uses any global state, so it can "
"be used more than once in the same thread. This is recommended if a network "
"request causes a loading failure, if there is a fatal error, if you damage "
"the state of the runtime so badly that it is no longer usable, or for "
"certain testing purposes. It is not recommended for creating multiple "
"execution environments, for which you should use `pyodide.runPython(code, "
"{ globals : some_dict})`; {pr}`2391`"
msgstr ""

#: ../../../project/changelog.md:2007
msgid ""
"{{ Enhancement }} `pyodide.unpackArchive` now accepts any `ArrayBufferView` "
"or `ArrayBuffer` as first argument, rather than only a `Uint8Array`. {pr}"
"`2451`"
msgstr ""

#: ../../../project/changelog.md:2011
msgid "{{ Feature }} Added `pyodide.code.run_js` API. {pr}`2426`"
msgstr ""

#: ../../../project/changelog.md:2014
msgid ""
"{{ Fix }} BigInt's between 2^{32\\*n - 1} and 2^{32\\*n} no longer get "
"translated to negative Python ints. {pr}`2484`"
msgstr ""

#: ../../../project/changelog.md:2018
msgid ""
"{{ Fix }} Pyodide now correctly handles JavaScript objects with `null` "
"constructor. {pr}`2520`"
msgstr ""

#: ../../../project/changelog.md:2022
msgid "{{ Fix }} Fix garbage collection of `once_callable` {pr}`2401`"
msgstr ""

#: ../../../project/changelog.md:2024
msgid ""
"{{ Enhancement }} Added the `js_id` attribute to `JsProxy` to allow using "
"JavaScript object identity as a dictionary key. {pr}`2515`"
msgstr ""

#: ../../../project/changelog.md:2028
msgid ""
"{{ Fix }} Fixed a bug with `toJs` when used with recursive structures and "
"the `dictConverter` argument. {pr}`2533`"
msgstr ""

#: ../../../project/changelog.md:2032
msgid ""
"{{ Enhancement }} Added Python wrappers `set_timeout`, `clear_timeout`, "
"`set_interval`, `clear_interval`, `add_event_listener` and "
"`remove_event_listener` for the corresponding JavaScript functions. {pr}"
"`2456`"
msgstr ""

#: ../../../project/changelog.md:2037
msgid ""
"{{ Fix }} If a request fails due to CORS, `pyfetch` now raises an `OSError` "
"not a `JSException`. {pr}`2598`"
msgstr ""

#: ../../../project/changelog.md:2041
msgid ""
"{{ Enhancement }} Pyodide now directly exposes the Emscripten `PATH` and "
"`ERRNO_CODES` APIs. {pr}`2582`"
msgstr ""

#: ../../../project/changelog.md:2045
msgid ""
"{{ Fix }} The `bool` operator on a `JsProxy` now behaves more consistently: "
"it returns `False` if JavaScript would say that `!!x` is `false`, or if `x` "
"is an empty container. Otherwise it returns `True`. {pr}`2803`"
msgstr ""

#: ../../../project/changelog.md:2050
msgid ""
"{{ Fix }} Fix `loadPyodide` errors for the Windows Node environment. {pr}"
"`2888`"
msgstr ""

#: ../../../project/changelog.md:2053
msgid ""
"{{ Enhancement }} Implemented slice subscripting, `+=`, and `extend` for "
"`JsProxy` of Javascript arrays. {pr}`2907`"
msgstr ""

#: ../../../project/changelog.md:2059
msgid "{{ Enhancement }} Add a spinner while the REPL is loading {pr}`2635`"
msgstr ""

#: ../../../project/changelog.md:2062
msgid ""
"{{ Enhancement }} Cursor blinking in the REPL can be disabled by setting "
"`noblink` in URL search params. {pr}`2666`"
msgstr ""

#: ../../../project/changelog.md:2066
msgid ""
"{{ Fix }} Fix a REPL error in printing high-dimensional lists. {pr}`2517` "
"{pr}`2919`"
msgstr ""

#: ../../../project/changelog.md:2069
msgid ""
"{{ Fix }} Fix output bug with using `input()` on online console {pr}`2509`"
msgstr ""

#: ../../../project/changelog.md:2072
msgid "micropip and package loading"
msgstr ""

#: ../../../project/changelog.md:2074
msgid ""
"{{ API }} `packages.json` which contains the dependency graph for packages "
"was renamed to `repodata.json` to avoid confusion with `package.json` used "
"in JavaScript packages."
msgstr ""

#: ../../../project/changelog.md:2078
msgid ""
"{{ Enhancement }} Added SHA-256 hash of package to entries in `repodata."
"json` {pr}`2455`"
msgstr ""

#: ../../../project/changelog.md:2081
msgid ""
"{{ Enhancement }} Integrity of Pyodide packages is now verified before "
"loading them. This is for now limited to browser environments. {pr}`2513`"
msgstr ""

#: ../../../project/changelog.md:2085
msgid ""
"{{ Enhancement }} `micropip` supports loading wheels from the Emscripten "
"file system using the `emfs:` protocol now. {pr}`2767`"
msgstr ""

#: ../../../project/changelog.md:2089
msgid ""
"{{ Enhancement }} It is now possible to use an alternate `repodata.json` "
"lockfile by passing the `lockFileURL` option to `loadPyodide`. This is "
"particularly intended to be used with `micropip.freeze`. {pr}`2645`"
msgstr ""

#: ../../../project/changelog.md:2094
msgid ""
"{{ Fix }} micropip now correctly handles package names that include dashes "
"{pr}`2414`"
msgstr ""

#: ../../../project/changelog.md:2097
msgid ""
"{{ Enhancement }} Allow passing `credentials` to `micropip.install()` {pr}"
"`2458`"
msgstr ""

#: ../../../project/changelog.md:2100
msgid ""
"{{ Enhancement }} {func}`micropip.install` now accepts a `deps` parameter. "
"If set to `False`, micropip will not install dependencies of the package. "
"{pr}`2433`"
msgstr ""

#: ../../../project/changelog.md:2104
msgid ""
"{{ Fix }} micropip now correctly compares packages with prerelease version "
"{pr}`2532`"
msgstr ""

#: ../../../project/changelog.md:2107
msgid ""
"{{ Enhancement }} {func}`micropip.install` now accepts a `pre` parameter. If "
"set to `True`, micropip will include pre-release and development versions. "
"{pr}`2542`"
msgstr ""

#: ../../../project/changelog.md:2111
msgid ""
"{{ Enhancement }} `micropip` was refactored to improve readability and ease "
"of maintenance. {pr}`2561`, {pr}`2563`, {pr}`2564`, {pr}`2565`, {pr}`2568`"
msgstr ""

#: ../../../project/changelog.md:2115
msgid ""
"{{ Enhancement }} Various error messages were fine tuned and improved. {pr}"
"`2562`, {pr}`2558`"
msgstr ""

#: ../../../project/changelog.md:2118
msgid ""
"{{ Enhancement }} `micropip` was adjusted to keep its state in the wheel `."
"dist-info` directories which improves consistenency with the Python standard "
"library and other tools used to install packages. {pr}`2572`"
msgstr ""

#: ../../../project/changelog.md:2123
msgid ""
"{{ Enhancement }} `micropip` can now be used to install Emscripten binary "
"wheels. {pr}`2591`"
msgstr ""

#: ../../../project/changelog.md:2126
msgid ""
"{{ Enhancement }} Added `micropip.freeze` to record the current set of "
"loaded packages into a `repodata.json` file. {pr}`2581`"
msgstr ""

#: ../../../project/changelog.md:2130
msgid ""
"{{ Fix }} `micropip.list` now works correctly when there are packages that "
