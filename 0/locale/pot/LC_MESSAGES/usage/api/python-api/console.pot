#: ../../../../src/py/pyodide/console.py:docstring of
#: pyodide.console.Console.push:1
msgid "Push a line to the interpreter."
msgstr ""

#: ../../../../src/py/pyodide/console.py:docstring of
#: pyodide.console.Console.push:3
msgid ""
"The line should not have a trailing newline; it may have internal newlines.  "
"The line is appended to a buffer and the interpreter's :py:meth:`~Console."
"runsource` method is called with the concatenated contents of the buffer as "
"source.  If this indicates that the command was executed or invalid, the "
"buffer is reset; otherwise, the command is incomplete, and the buffer is "
"left as it was after the line was appended."
msgstr ""

#: ../../../../src/py/pyodide/console.py:docstring of
#: pyodide.console.Console.push:10
msgid ""
"The return value is the result of calling :py:meth:`~Console.runsource` on "
"the current buffer contents."
msgstr ""

