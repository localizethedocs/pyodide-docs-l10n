#: ../../../usage/socket.md:3
msgid "Using Sockets"
msgstr ""

#: ../../../usage/socket.md:5
msgid "This is experimental"
msgstr ""

#: ../../../usage/socket.md:8
msgid ""
"This feature is experimental and may change or be removed in future versions "
"of Pyodide. This feature is only available in Node.js and is not supported "
"in browsers."
msgstr ""

#: ../../../usage/socket.md:12
msgid ""
"By default, Pyodide does not support sockets in the browser. Browsers do not "
"provide a standard low-level socket API, so Pyodide does not include a "
"browser socket implementation and raises an error if your code tries to use "
"sockets there."
msgstr ""

#: ../../../usage/socket.md:16
msgid ""
"If you are running Pyodide in Node.js, you can enable an experimental socket "
"API."
msgstr ""

#: ../../../usage/socket.md:18
msgid "Enabling socket support"
msgstr ""

#: ../../../usage/socket.md:20
msgid ""
"Call `await pyodide.useNodeSockFS()` before importing any Python modules "
"that use sockets."
msgstr ""

#: ../../../usage/socket.md:22
msgid ""
"const pyodide = await loadPyodide();\n"
"await pyodide.useNodeSockFS();\n"
msgstr ""

#: ../../../usage/socket.md:27
msgid "This feature requires JavaScript Promise Integration."
msgstr ""

#: ../../../usage/socket.md:29
msgid ""
"If you are using Node.js <= 24, enable it explicitly with the `--"
"experimental-wasm-stack-switching` flag:"
msgstr ""

#: ../../../usage/socket.md:31
msgid "node --experimental-wasm-stack-switching\n"
msgstr ""

#: ../../../usage/socket.md:35
msgid ""
"If you are using Node.js >= 25, Promise Integration is enabled by default."
msgstr ""

#: ../../../usage/socket.md:37
msgid "After this setup, you can use sockets in Python as usual."
msgstr ""

#: ../../../usage/socket.md:39
msgid "Example"
msgstr ""

#: ../../../usage/socket.md:41
msgid "Using sockets directly in Python"
msgstr ""

#: ../../../usage/socket.md:43
msgid ""
"import socket\n"
"\n"
"# Create a socket\n"
"s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n"
"# Connect to a server\n"
"s.connect(('localhost', 8080))\n"
"# Send some data\n"
"s.sendall(b'Hello, world')\n"
"# Receive some data\n"
"data = s.recv(1024)\n"
"print('Received', repr(data))\n"
"# Close the socket\n"
"s.close()\n"
msgstr ""

#: ../../../usage/socket.md:59
msgid "Using sockets with database drivers"
msgstr ""

#: ../../../usage/socket.md:61
msgid ""
"Many database drivers use sockets to connect to a database server. With "
"socket support enabled, you can use these drivers in Pyodide on Node.js."
msgstr ""

#: ../../../usage/socket.md:64
msgid ""
"For example, you can use the `pymysql` driver to connect to a MySQL database:"
msgstr ""

#: ../../../usage/socket.md:66
msgid ""
"import pymysql\n"
"\n"
"# Connect to the database\n"
"connection = pymysql.connect(host='localhost', user='user', "
"password='password', database='test')\n"
"# Create a cursor\n"
"cursor = connection.cursor()\n"
"# Execute a query\n"
"cursor.execute('SELECT * FROM my_table')\n"
"# Fetch the results\n"
"results = cursor.fetchall()\n"
"print(results)\n"
"# Close the connection\n"
"connection.close()\n"
msgstr ""
