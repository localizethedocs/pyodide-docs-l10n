"when [importing Python objects into JavaScript](type-translations_using-py-"
"obj-from-js)"
msgstr ""

#: ../../../usage/type-conversions.md:23
msgid "when passing arguments to a JavaScript function called from Python,"
msgstr ""

#: ../../../usage/type-conversions.md:24
msgid "when returning the results of a Python function called from JavaScript,"
msgstr ""

#: ../../../usage/type-conversions.md:25
msgid "when accessing an attribute of a {js:class}`~pyodide.ffi.PyProxy`"
msgstr ""

