msgid "JavaScript to Python translations occur:"
msgstr ""

#: ../../../usage/type-conversions.md:29
msgid ""
"when [importing from the `js` module](type-translations_using-js-obj-from-py)"
msgstr ""

#: ../../../usage/type-conversions.md:30
