msgid "Python to JavaScript translations occur:"
msgstr ""

#: ../../../usage/type-conversions.md:21
msgid ""
"when returning the final expression from a {js:func}`pyodide.runPython` call,"
msgstr ""

#: ../../../usage/type-conversions.md:22
