#: ../../../usage/wasm-constraints.md:94
msgid "Threading and multiprocessing"
msgstr ""

#: ../../../usage/wasm-constraints.md:96
msgid ""
"Because Pyodide does not support threading or multiprocessing, packages that "
"use threading or multiprocessing will not work without a patch to disable "
"it. For example, the following snippet will determine if the platform "
"supports creating new threads."
msgstr ""

#: ../../../usage/wasm-constraints.md:100
msgid ""
"def _can_start_thread() -> bool:\n"
"    if sys.platform == \"emscripten\":\n"
"        return sys._emscripten_info.pthreads\n"
"    return platform.machine() not in (\"wasm32\", \"wasm64\")\n"
"\n"
"can_start_thread = _can_start_thread()\n"
"\n"
"if not can_start_thread:\n"
"  n_threads = 1\n"
msgstr ""
