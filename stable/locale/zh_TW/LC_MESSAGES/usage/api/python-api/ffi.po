#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:3
msgid ""
"This is similar to :js:meth:`~pyodide.ffi.PyProxy.toJs`, but for use from "
"Python. If the object can be implicitly translated to JavaScript, it will be "
"returned unchanged. If the object cannot be converted into JavaScript, this "
"method will return a :py:class:`JsProxy` of a :js:class:`~pyodide.ffi."
"PyProxy`, as if you had used :func:`~pyodide.ffi.create_proxy`."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:10
msgid "See :ref:`type-translations-pyproxy-to-js` for more information."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:13
msgid "The Python object to convert"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:15
msgid ""
"The maximum depth to do the conversion. Negative numbers are treated as "
"infinite. Set this to 1 to do a shallow conversion."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:18
msgid ""
"Should be a JavaScript :js:class:`Array`. If provided, any ``PyProxies`` "
"generated will be stored here. You can later use :py:meth:`destroy_proxies` "
"if you want to destroy the proxies from Python (or from JavaScript you can "
"just iterate over the :js:class:`Array` and destroy the proxies)."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:24
msgid ""
"If you set this to :py:data:`False`, :py:func:`to_js` will raise an error "
"rather than creating any pyproxies."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:27
msgid ""
"This converter if provided receives a (JavaScript) iterable of (JavaScript) "
"pairs [key, value]. It is expected to return the desired result of the dict "
"conversion. Some suggested values for this argument:    * ``js.Object."
"fromEntries`` -- similar to the default behavior   * ``js.Map.new`` -- "
"convert to a map   * ``js.Array.from`` -- convert to an array of entries"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:27
msgid ""
"This converter if provided receives a (JavaScript) iterable of (JavaScript) "
"pairs [key, value]. It is expected to return the desired result of the dict "
"conversion. Some suggested values for this argument:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:31
msgid "``js.Object.fromEntries`` -- similar to the default behavior"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:32
msgid "``js.Map.new`` -- convert to a map"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:33
msgid "``js.Array.from`` -- convert to an array of entries"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:35
msgid ""
"If present will be invoked whenever Pyodide does not have some built in "
"conversion for the object. If ``default_converter`` raises an error, the "
"error will be allowed to propagate. Otherwise, the object returned will be "
"used as the conversion. ``default_converter`` takes three arguments. The "
"first argument is the value to be converted."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:41
msgid ""
"If present will be invoked whenever the object is not an ``int``, ``float``, "
"``bool``, ``None``, or a ``JsProxy``. It is called before the default "
"conversions are applied to lists, tuples, dictionaries, and sets, so it can "
"be used to override these. By contrast, ``default_converter`` is used as a "
"fallback.  If ``eager_converter`` raises an error, the error will be allowed "
"to propagate. Otherwise, the object returned will be used as the conversion. "
"``default_converter`` takes three arguments. The first argument is the value "
"to be converted."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:41
msgid ""
"If present will be invoked whenever the object is not an ``int``, ``float``, "
"``bool``, ``None``, or a ``JsProxy``. It is called before the default "
"conversions are applied to lists, tuples, dictionaries, and sets, so it can "
"be used to override these. By contrast, ``default_converter`` is used as a "
"fallback."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:47
msgid ""
"If ``eager_converter`` raises an error, the error will be allowed to "
"propagate. Otherwise, the object returned will be used as the conversion. "
"``default_converter`` takes three arguments. The first argument is the value "
"to be converted."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:83
msgid ""
"Here are some examples demonstrating the usage of the ``default_converter`` "
"argument."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:86
msgid ""
"In addition to the normal conversions, convert JavaScript :js:class:`Date` "
"objects to :py:class:`~datetime.datetime` objects:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:89
msgid ""
"from datetime import datetime\n"
"from js import Date\n"
"def default_converter(value, _ignored1, _ignored2):\n"
"    if isinstance(value, datetime):\n"
"        return Date.new(value.timestamp() * 1000)\n"
"    return value"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:98
msgid ""
"Don't create any PyProxies, require a complete conversion or raise an error:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:105
msgid ""
"The second and third arguments are only needed for converting containers. "
"The second argument is a conversion function which is used to convert the "
"elements of the container with the same settings. The third argument is a "
"\"cache\" function which is needed to handle self referential containers. "
"Consider the following example. Suppose we have a Python ``Pair`` class:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:111
msgid ""
"class Pair:\n"
"    def __init__(self, first, second):\n"
"        self.first = first\n"
"        self.second = second"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:118
msgid ""
"We can use the following ``default_converter`` to convert ``Pair`` to :js:"
"class:`Array`:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:121
msgid ""
"from js import Array\n"
"\n"
"def default_converter(value, convert, cache):\n"
"    if not isinstance(value, Pair):\n"
"        return value\n"
"    result = Array.new()\n"
"    cache(value, result)\n"
"    result.push(convert(value.first))\n"
"    result.push(convert(value.second))\n"
"    return result"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:138
msgid "p = Pair(0, 0); p.first = p;"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:142
msgid ""
"Without ``cache(value, result);``, converting ``p`` would lead to an "
"infinite recurse. With it, we can successfully convert ``p`` to an Array "
"such that ``l[0] === l``."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:146
msgid ""
"Here are some examples demonstrating the usage of the ``eager_converter`` "
"argument. Calling `convert(value)` does the normal conversion, so setting "
"`eager_converter` to the following function is the same as leaving it unset "
"(except for being slower):"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:151
msgid ""
"def apply_normal_conversion(value, convert, cacheConversion):\n"
"    return convert(value)"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:157
msgid ""
"The following `eager_converter` will fail the conversion if a tuple is "
"passed:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:160
msgid ""
"from pyodide.ffi import ConversionError\n"
"\n"
"def reject_tuples(value, convert, cacheConversion):\n"
"    if isinstance(value, tuple):\n"
"        raise ConversionError(\"We don't convert tuples!\")\n"
"    return convert(value)"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:169
msgid "The following `eager_converter` makes tuples into a `PyProxy`:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of pyodide.ffi.to_js:171
msgid ""
"def proxy_tuples(value, convert, cacheConversion):\n"
"    if isinstance(value, tuple):\n"
"        return value\n"
"    return convert(value)"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: _pyodide._importhook.JsFinder.unregister_js_module:1
msgid ""
"Unregisters a JavaScript module with given name that has been previously "
"registered with :js:func:`pyodide.registerJsModule` or :py:func:`pyodide.ffi."
"register_js_module`. If a JavaScript module with that name does not already "
"exist, will raise an error. If the module has already been imported, this "
"won't have much effect unless you also delete the imported module from :py:"
"data:`sys.modules`. This is called by the JavaScript API :js:func:`pyodide."
"unregisterJsModule`."
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: _pyodide._importhook.JsFinder.unregister_js_module:10
