"example:  .. code-block:: python      from js import Array      def "
"default_converter(value, convert, cache):         if not isinstance(value, "
"Pair):             return value         result = Array.new() cache(value, "
"result)         result.push(convert(value.first))         result."
"push(convert(value.second))         return result"
