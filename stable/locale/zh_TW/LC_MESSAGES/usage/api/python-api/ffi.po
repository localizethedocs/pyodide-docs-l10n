msgid ""
"Here are a couple examples of converter functions. In addition to the normal "
"conversions, convert :js:class:`Date` to :py:class:`~datetime.datetime`:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:23 pyodide.ffi.JsProxy.to_py:23
msgid ""
"from datetime import datetime\n"
"def default_converter(value, _ignored1, _ignored2):\n"
"    if value.constructor.name == \"Date\":\n"
"        return datetime.fromtimestamp(d.valueOf()/1000)\n"
"    return value"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:31 pyodide.ffi.JsProxy.to_py:31
msgid ""
"Don't create any JsProxies, require a complete conversion or raise an error:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:33 pyodide.ffi.JsProxy.to_py:33
#: pyodide.ffi.to_js:100
msgid ""
"def default_converter(_value, _ignored1, _ignored2):\n"
"    raise Exception(\"Failed to completely convert object\")"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:38 pyodide.ffi.JsProxy.to_py:38
msgid ""
"The second and third arguments are only needed for converting containers. "
"The second argument is a conversion function which is used to convert the "
"elements of the container with the same settings. The third argument is a "
"\"cache\" function which is needed to handle self referential containers. "
"Consider the following example. Suppose we have a Javascript ``Pair`` class:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:45 pyodide.ffi.JsProxy.to_py:45
msgid ""
"class Pair {\n"
"    constructor(first, second){\n"
"        this.first = first;\n"
"        this.second = second;\n"
"    }\n"
"}"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:54 pyodide.ffi.JsProxy.to_py:54
msgid ""
"We can use the following ``default_converter`` to convert ``Pair`` to :py:"
"class:`list`:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:56 pyodide.ffi.JsProxy.to_py:56
msgid ""
"def default_converter(value, convert, cache):\n"
"    if value.constructor.name != \"Pair\":\n"
"        return value\n"
"    result = []\n"
"    cache(value, result);\n"
"    result.append(convert(value.first))\n"
"    result.append(convert(value.second))\n"
"    return result"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:67 pyodide.ffi.JsProxy.to_py:67
#: pyodide.ffi.to_js:134
msgid ""
"Note that we have to cache the conversion of ``value`` before converting "
"``value.first`` and ``value.second``. To see why, consider a self "
"referential pair:"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:71 pyodide.ffi.JsProxy.to_py:71
msgid ""
"let p = new Pair(0, 0);\n"
"p.first = p;"
msgstr ""

#: ../../../../src/py/_pyodide/_core_docs.py:docstring of
#: pyodide.ffi.JsArray.to_py:76 pyodide.ffi.JsProxy.to_py:76
msgid ""
"Without ``cache(value, result);``, converting ``p`` would lead to an "
"infinite recurse. With it, we can successfully convert ``p`` to a list such "
"that ``l[0] is l``."
msgstr ""

