#: ../../../usage/api/python-api/http.md:1
msgid "pyodide.http"
msgstr ""

#: ../../../usage/api/python-api/http.md:3
msgid ""
"The `pyodide.http` module provides HTTP client functionality specifically "
"designed for browser and WebAssembly environments where traditional Python "
"HTTP libraries (like `urllib`) face significant limitations."
msgstr ""

#: ../../../usage/api/python-api/http.md:5
msgid "Network Limitations in Pyodide"
msgstr ""

#: ../../../usage/api/python-api/http.md:7
msgid ""
"Due to browser security constraints and WebAssembly's sandboxed environment, "
"standard Python networking libraries have several limitations:"
msgstr ""

#: ../../../usage/api/python-api/http.md:9
msgid ""
"**No raw socket access**: Browser security prevents direct socket operations"
msgstr ""

#: ../../../usage/api/python-api/http.md:10
msgid ""
"**CORS restrictions**: Cross-origin requests are limited by browser CORS "
"policies"
msgstr ""

#: ../../../usage/api/python-api/http.md:11
msgid ""
"**No synchronous networking in main thread**: Traditional blocking HTTP "
"calls can freeze the browser UI"
msgstr ""

#: ../../../usage/api/python-api/http.md:12
msgid ""
"**Limited protocol support**: Only HTTP/HTTPS protocols are available, no "
"TCP/UDP sockets"
msgstr ""

#: ../../../usage/api/python-api/http.md:14
msgid "HTTP Client Alternatives"
msgstr ""

#: ../../../usage/api/python-api/http.md:16
msgid "Pyodide provides two complementary HTTP client solutions:"
msgstr ""

#: ../../../usage/api/python-api/http.md:18
msgid "`pyfetch` - Asynchronous HTTP Client"
msgstr ""

#: ../../../usage/api/python-api/http.md:20
msgid "Based on the browser's native Fetch API, `pyfetch` provides:"
msgstr ""

#: ../../../usage/api/python-api/http.md:21
msgid ""
"**Asynchronous operations**: Non-blocking HTTP requests using async/await"
msgstr ""

#: ../../../usage/api/python-api/http.md:22
msgid ""
"**Full browser integration**: Leverages browser's networking stack and "
"security features"
msgstr ""

#: ../../../usage/api/python-api/http.md:23
msgid ""
"**Modern API**: Clean, Promise-based interface similar to JavaScript fetch()"
msgstr ""

#: ../../../usage/api/python-api/http.md:25
msgid ""
"# Asynchronous HTTP request\n"
"from pyodide.http import pyfetch\n"
"response = await pyfetch(\"https://api.example.com/data\")\n"
"data = await response.json()\n"
msgstr ""

#: ../../../usage/api/python-api/http.md:32
msgid "`pyxhr` - Synchronous HTTP Client"
msgstr ""

#: ../../../usage/api/python-api/http.md:34
msgid "Based on XMLHttpRequest, `pyxhr` provides:"
msgstr ""

#: ../../../usage/api/python-api/http.md:35
msgid ""
"**Synchronous operations**: Blocking HTTP requests for simpler code patterns"
msgstr ""

#: ../../../usage/api/python-api/http.md:36
msgid "**requests-like API**: Familiar interface for Python developers"
msgstr ""

#: ../../../usage/api/python-api/http.md:37
msgid ""
"**Browser compatibility**: Works in all modern browsers supporting "
"XMLHttpRequest"
msgstr ""

#: ../../../usage/api/python-api/http.md:38
msgid "**Lightweight**: Minimal overhead for simple HTTP operations"
msgstr ""

#: ../../../usage/api/python-api/http.md:40
msgid ""
"# Synchronous HTTP request\n"
"from pyodide.http import pyxhr\n"
"response = pyxhr.get(\"https://api.example.com/data\")\n"
"data = response.json()\n"
msgstr ""

#: ../../../usage/api/python-api/http.md:47
msgid "Choosing Between pyfetch and pyxhr"
msgstr ""

#: ../../../usage/api/python-api/http.md:49
msgid "**Use `pyfetch` when:**"
msgstr ""

#: ../../../usage/api/python-api/http.md:50
msgid "Working with async/await patterns"
msgstr ""

#: ../../../usage/api/python-api/http.md:51
msgid "Need advanced features like streaming or request cancellation"
msgstr ""

#: ../../../usage/api/python-api/http.md:52
msgid "Building responsive web applications that shouldn't block the UI"
msgstr ""

#: ../../../usage/api/python-api/http.md:53
msgid "Integrating with other asynchronous Python code"
msgstr ""

#: ../../../usage/api/python-api/http.md:55
msgid "**Use `pyxhr` when:**"
msgstr ""

#: ../../../usage/api/python-api/http.md:56
msgid "Prefer synchronous, blocking operations"
msgstr ""

#: ../../../usage/api/python-api/http.md:57
msgid "Porting existing code that uses requests-like patterns"
msgstr ""

#: ../../../usage/api/python-api/http.md:58
msgid "Need simple HTTP operations without async complexity"
msgstr ""

#: ../../../usage/api/python-api/http.md:59
msgid "Working in environments where sync operations are acceptable"
msgstr ""

